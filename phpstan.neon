includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
parameters:
    level: 6
    phpVersion: 80400 # Force l'analyse pour PHP 8.4
    treatPhpDocTypesAsCertain: false
    paths:
        - eg-media.php
        - includes/
    bootstrapFiles:
        - tests/phpstan/bootstrap.php
    scanFiles:
        - eg-media.php
